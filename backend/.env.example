# Comma-separated list of allowed frontend origins.
# Local dev defaults are already baked in, only add production URLs here.
ALLOWED_ORIGINS=https://your-app.vercel.app,https://your-custom-domain.com

# Regex that allows every Vercel preview deployment by default.
ALLOWED_ORIGIN_REGEX=https://.*\.vercel\.app

# Long random string used to sign JWTs. Render generates this automatically.
JWT_SECRET=change-me-to-a-long-random-string

# JWT lifetime in minutes (default 480 = 8h)
JWT_EXPIRE_MINUTES=480

# Port the server listens on. Platforms inject this automatically.
PORT=8000
